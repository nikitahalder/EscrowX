generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  FREELANCER
  ARBITRATOR
  ADMIN
}

enum ProjectStatus {
  CREATED
  AWAITING_FUNDING
  FUNDED
  FREELANCER_ACCEPTED
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  COMPLETED
  DISPUTED
  RESOLVED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}

enum DisputeResolution {
  FULL_CLIENT_REFUND
  FULL_FREELANCER_PAYMENT
  PARTIAL_SPLIT
}

model User {
  id             String   @id @default(cuid())
  walletAddress  String   @unique
  role           UserRole @default(CLIENT)
  displayName    String?
  avatarUrl      String?
  bio            String?
  reputationScore Float   @default(0)
  totalProjects  Int      @default(0)
  completedProjects Int   @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clientProjects     Project[]   @relation("ClientProjects")
  freelancerProjects Project[]   @relation("FreelancerProjects")
  arbitratedProjects Project[]   @relation("ArbitratedProjects")
  sentMessages       Message[]
  disputesRaised     Dispute[]   @relation("DisputeRaiser")
  reviewsGiven       Review[]    @relation("ReviewGiver")
  reviewsReceived    Review[]    @relation("ReviewReceiver")
  auditLogs          AuditLog[]

  @@index([walletAddress])
}

model Project {
  id              String        @id @default(cuid())
  contractId      String?       // on-chain project ID (u64 as string)
  clientId        String
  freelancerId    String?
  arbitratorId    String?
  title           String
  description     String        @db.Text
  budget          Decimal       @db.Decimal(18, 7)
  tokenAddress    String        @default("CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA")
  status          ProjectStatus @default(AWAITING_FUNDING)
  txHash          String?       // funding tx hash
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?

  client          User          @relation("ClientProjects", fields: [clientId], references: [id])
  freelancer      User?         @relation("FreelancerProjects", fields: [freelancerId], references: [id])
  arbitrator      User?         @relation("ArbitratedProjects", fields: [arbitratorId], references: [id])
  milestones      Milestone[]
  messages        Message[]
  dispute         Dispute?
  reviews         Review[]
  auditLogs       AuditLog[]

  @@index([clientId])
  @@index([freelancerId])
  @@index([status])
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  contractIdx Int             // 0-based index in contract
  title       String
  description String          @db.Text
  amount      Decimal         @db.Decimal(18, 7)
  dueDate     DateTime?
  status      MilestoneStatus @default(PENDING)
  proofHash         String?         // on-chain IPFS/hash
  rejectionFeedback String?         @db.Text
  order             Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submission  Submission?

  @@index([projectId])
  @@index([status])
}

model Submission {
  id            String    @id @default(cuid())
  milestoneId   String    @unique
  githubUrl     String?
  deploymentUrl String?
  notes         String?   @db.Text
  files         Json      @default("[]")
  txHash        String?   // on-chain submit tx
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  milestone     Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  files_meta    UploadedFile[]

  @@index([milestoneId])
}

model UploadedFile {
  id           String    @id @default(cuid())
  submissionId String
  fileName     String
  fileKey      String    // R2 key
  fileUrl      String
  fileSize     Int
  mimeType     String
  createdAt    DateTime  @default(now())

  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Dispute {
  id          String           @id @default(cuid())
  projectId   String           @unique
  milestoneId String?
  raisedById  String
  reason      String
  description String           @db.Text
  status      DisputeStatus    @default(OPEN)
  resolution  DisputeResolution?
  clientBps   Int?             // basis points to client in partial split
  txHash      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  resolvedAt  DateTime?

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  raisedBy    User             @relation("DisputeRaiser", fields: [raisedById], references: [id])
  evidence    DisputeEvidence[]

  @@index([projectId])
  @@index([status])
}

model DisputeEvidence {
  id         String    @id @default(cuid())
  disputeId  String
  uploadedBy String
  fileName   String
  fileKey    String
  fileUrl    String
  fileSize   Int
  mimeType   String
  notes      String?
  createdAt  DateTime  @default(now())

  dispute    Dispute   @relation(fields: [disputeId], references: [id], onDelete: Cascade)
}

model Message {
  id         String    @id @default(cuid())
  projectId  String
  senderId   String
  content    String    @db.Text
  fileUrl    String?
  fileName   String?
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender     User      @relation(fields: [senderId], references: [id])

  @@index([projectId])
  @@index([senderId])
}

model Review {
  id          String    @id @default(cuid())
  projectId   String
  reviewerId  String
  targetId    String
  rating      Int       // 1-5
  reviewText  String?   @db.Text
  createdAt   DateTime  @default(now())

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer    User      @relation("ReviewGiver", fields: [reviewerId], references: [id])
  target      User      @relation("ReviewReceiver", fields: [targetId], references: [id])

  @@unique([projectId, reviewerId])
  @@index([targetId])
}

model AuditLog {
  id        String    @id @default(cuid())
  projectId String?
  userId    String?
  action    String
  details   Json
  txHash    String?
  createdAt DateTime  @default(now())

  project   Project?  @relation(fields: [projectId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}
